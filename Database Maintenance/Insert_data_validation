DROP PROCEDURE IF EXISTS dc.InsertComment;
DELIMITER $$
CREATE PROCEDURE dc.InsertComment(
    IN p_email       VARCHAR(255),
    IN p_commentText TEXT,
    IN p_appSource   VARCHAR(100)
)
BEGIN

    DECLARE v_error_code INT DEFAULT 0;
    DECLARE v_error_msg  VARCHAR(200) DEFAULT '';

    -- Fire this handler on any SQL exception and log it
    DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
    BEGIN
        GET DIAGNOSTICS CONDITION 1
            v_error_code = MYSQL_ERRNO,
            v_error_msg  = MESSAGE_TEXT;
        INSERT INTO logging.ProcedureErrors
            (Host_Name, Procedure_Name, Error_Code, Error_Str, Severity)
        VALUES
            (@@hostname, 'InsertComment', v_error_code, v_error_msg, 'ERROR');
    END;



    -- NULL or empty email check
    IF p_email IS NULL OR TRIM(p_email) = '' THEN
        SIGNAL SQLSTATE '45000'
            SET MESSAGE_TEXT = 'InsertComment: email cannot be null or empty';
    END IF;

    -- Basic email format: must have exactly one @ with chars on both sides
    IF p_email NOT REGEXP '^[A-Za-z0-9._%+\\-]+@[A-Za-z0-9.\\-]+\\.[A-Za-z]{2,}$' THEN
        SIGNAL SQLSTATE '45000'
            SET MESSAGE_TEXT = 'InsertComment: email format is invalid';
    END IF;

    -- Comment text shouldn't be blank -- what's the point of an empty comment?
    IF p_commentText IS NULL OR TRIM(p_commentText) = '' THEN
        SIGNAL SQLSTATE '45000'
            SET MESSAGE_TEXT = 'InsertComment: commentText cannot be null or empty';
    END IF;

    -- appSource tells us where this came from, I need it populated
    IF p_appSource IS NULL OR TRIM(p_appSource) = '' THEN
        SIGNAL SQLSTATE '45000'
            SET MESSAGE_TEXT = 'InsertComment: appSource cannot be null or empty';
    END IF;

    -- ── Insert ───────────────────────────────────────────────
    INSERT INTO Comments (email, commentText, appSource)
    VALUES (p_email, p_commentText, p_appSource);

    -- Return the newly created comment back to the caller
    SELECT email, createdAt
    FROM Comments
    WHERE email = p_email
    ORDER BY createdAt DESC
    LIMIT 1;

END$$
DELIMITER ;
